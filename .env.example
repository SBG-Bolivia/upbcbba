# ─── AWS certificate system ─────────────────────────────────────────────────
# Copy to .env.local for local dev. In production set these in the Amplify
# console (App settings → Environment variables). Do NOT put AWS access keys
# here — the SDK uses your local AWS CLI profile in dev and the Amplify compute
# role in production.

# Region where the resources live (Lambda/Amplify sets AWS_REGION automatically).
SBG_AWS_REGION=us-east-1

# S3 bucket holding the certificate template + generated PDFs (globally unique).
SBG_S3_BUCKET=
# Key of the AWS-provided certificate template PDF inside that bucket.
SBG_CERT_TEMPLATE_KEY=templates/certificate-template.pdf

# DynamoDB table names (defaults shown — only override if you renamed them).
SBG_DDB_EVENTS=sbg-cert-events
SBG_DDB_PARTICIPANTS=sbg-cert-participants
SBG_DDB_ATTENDANCE=sbg-cert-attendance
SBG_DDB_CERTIFICATES=sbg-cert-certificates

# Verified SES sender (email or domain identity) for certificate emails.
SBG_SES_SENDER=certificados@tudominio.com

# Public base URL — used to build the QR + email verification links.
NEXT_PUBLIC_BASE_URL=https://upbbuilders.example.com
